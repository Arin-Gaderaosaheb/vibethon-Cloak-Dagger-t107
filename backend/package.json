{
  "name": "aiml-learning-backend",
  "version": "1.0.0",
  "description": "AIML Interactive Learning Prototype - Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node -e \"const mysql=require('mysql2');const fs=require('fs');const db=mysql.createConnection({host:process.env.DB_HOST||'localhost',user:process.env.DB_USER||'root',password:process.env.DB_PASSWORD||''});db.query(fs.readFileSync('./migrations/001_create_tables.sql','utf8'),(e)=>{if(e)throw e;console.log('Migration done');db.end()})\"",
    "lint": "eslint src/**/*.js",
    "test": "echo \"Tests not yet configured\" && exit 0"
  },
  "keywords": [
    "aiml",
    "learning",
    "api",
    "express",
    "mysql"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.0"
  }
}
